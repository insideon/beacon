{
  "name": "beacon-ai",
  "version": "1.2.0",
  "description": "AI-powered CLI that analyzes your codebase and tells you what to work on next",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/insideon/beacon.git"
  },
  "homepage": "https://github.com/insideon/beacon",
  "bugs": {
    "url": "https://github.com/insideon/beacon/issues"
  },
  "keywords": [
    "ai",
