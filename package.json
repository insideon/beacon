    "open": "^11.0.0",
    "openai": "^6.33.0",
    "ora": "^9.3.0",
    "simple-git": "^3.25.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
